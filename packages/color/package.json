{
    "name": "@yakit-libs/color",
    "version": "1.2.0",
    "description": "A set of color designs derived from Yakit",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./generator": {
            "types": "./dist/generator.d.ts",
            "require": "./dist/generator.js",
            "default": "./dist/generator.js"
        },
        "./component": {
            "types": "./dist/component.d.ts",
            "require": "./dist/component.js",
            "default": "./dist/component.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "watch-build": "tsc --watch",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "@yakit-libs/color",
        "@yakit-libs"
    ],
    "author": "",
    "license": "MIT",
    "packageManager": "pnpm@10.12.4",
    "devDependencies": {
        "typescript": "^5.9.2"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/yaklang/YakitLibs",
        "directory": "packages/color"
    },
    "bugs": {
        "url": "https://github.com/yaklang/YakitLibs/issues"
    },
    "homepage": "https://github.com/yaklang/YakitLibs/packages/color/README.md"
}
