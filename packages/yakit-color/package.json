{
    "name": "yakit-color",
    "version": "1.0.0",
    "description": "A set of color designs derived from Yakit",
    "main": "dist/index.css",
    "style": "dist/index.css",
    "files": [
        "dist",
        "src",
        "postcss.config.js"
    ],
    "scripts": {
        "build": "sass src/index.scss | postcss -o  dist/index.css",
        "watch-build": "sass --watch src/index.scss | postcss -o  dist/index.css",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "yakit-color",
        "yakit"
    ],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.12.4",
    "devDependencies": {
        "cssnano": "^7.1.0",
        "postcss": "^8.5.6",
        "postcss-cli": "^11.0.1",
        "sass": "^1.90.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/yaklang/YakitLibs/tree/main/packages/yakit-color.git"
    }
}
